{
  "name": "@postfmly/logger",
  "version": "1.0.1",
  "description": "Info/error console logger",
  "keywords": [
    "info",
    "error",
    "console",
    "logger"
  ],
  "homepage": "https://github.com/chump29/logger",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chump29/logger.git"
  },
  "license": "GPL-3.0-only",
  "author": {
    "name": "Chris Post",
    "email": "admin@postfmly.com"
  },
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "bun run build:clean && bun run build:build && bun run build:dts && bun run build:copy",
    "build:build": "bun build ./index.ts --target node --minify --outdir dist",
    "build:clean": "rimraf dist",
    "build:copy": "cp -f LICENSE package.json README.md dist/",
    "build:dts": "bunx tsc --declaration --emitDeclarationOnly --outDir dist --noEmit false",
    "clean": "rimraf node_modules bun.lock",
    "lint": "biome check --write --verbose .",
    "test": "bun test --coverage"
  },
  "dependencies": {
    "date-and-time": "^4.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@postfmly/config": "^1.2.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "rimraf": "^6.1.3"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": "~1.3.13"
  },
  "engineStrict": true
}
