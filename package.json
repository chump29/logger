{
  "name": "@postfmly/logger",
  "version": "1.0.5",
  "description": "Info/error console logger",
  "keywords": [
    "info",
    "error",
    "console",
    "logger"
  ],
  "homepage": "https://github.com/chump29/logger",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chump29/logger.git"
  },
  "license": "GPL-3.0-only",
  "author": {
    "name": "Chris Post",
    "email": "admin@postfmly.com"
  },
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "bun run build:clean && bun run build:build && bun run build:dts && bun run build:copy && bun run build:rm",
    "build:build": "bun run build.ts",
    "build:clean": "rimraf dist",
    "build:copy": "cp -f LICENSE package.json README.md dist/",
    "build:dts": "bunx tsc --declaration --emitDeclarationOnly --outDir dist --noEmit false --skipLibCheck",
    "build:rm": "rm dist/index.test.d.ts dist/build.d.ts",
    "clean": "rimraf node_modules bun.lock .vscode dist coverage",
    "clean:coverage": "rimraf coverage",
    "lint": "biome check --write --verbose .",
    "prepare": "config-init",
    "test": "bun run clean:coverage && bun test --coverage --isolate --coverage-reporter=text --coverage-reporter=lcov"
  },
  "overrides": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "date-and-time": "^4.5.0"
  },
  "devDependencies": {
    "rimraf": "^6.1.3"
  },
  "peerDependencies": {
    "@postfmly/config": "^1.2.17"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "~1.3.14"
  },
  "engineStrict": true
}
